#!/usr/bin/env bash
#
# Post-commit hook — keep ``VITE_APP_VERSION`` in ``.env`` in sync with
# the current HEAD so the sidebar footer visibly reflects each commit.
#
# Format: ``2.0.<v2_change_count>`` (e.g. ``2.0.62``) — NO commit-SHA suffix (the Manažér doesn't want it on
# screen). ``<v2_change_count>`` = commits made on the v2 line since it forked from ``main`` (which is frozen /
# v1 PROD-pinned) — the REAL number of times we touched v2, NOT the whole-repo count (~690, which includes all
# of v1). It grows by 1 per v2 commit, so the sidebar shows how many times the project was actually changed.
# Only the single VITE_APP_VERSION line is touched — any other values in
# ``.env`` (backend secrets, local overrides) are preserved.
#
# Enable once per clone:
#   git config core.hooksPath .githooks
#
# The hook only writes (never reads) credential lines, so it is
# compatible with CLAUDE.md §13.

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
ENV_FILE="${REPO_ROOT}/.env"

# Count only the commits on the v2 line (since it forked from the frozen ``main``) — the real v2 change count.
BASE=$(git merge-base main HEAD 2>/dev/null || true)
if [[ -n "${BASE}" ]]; then
    V2_CHANGES=$(git rev-list --count "${BASE}..HEAD")
else
    V2_CHANGES=$(git rev-list --count HEAD)  # fallback when ``main`` is unavailable
fi
VERSION="2.0.${V2_CHANGES}"
NEW_LINE="VITE_APP_VERSION=${VERSION}"

if [[ -f "${ENV_FILE}" ]] && grep -q '^VITE_APP_VERSION=' "${ENV_FILE}"; then
    # Replace the existing line in-place, preserve everything else.
    sed -i "s|^VITE_APP_VERSION=.*|${NEW_LINE}|" "${ENV_FILE}"
else
    # First run (or line missing) — append. ``touch`` ensures the file
    # exists on a fresh clone where ``.env`` has never been created.
    touch "${ENV_FILE}"
    printf '%s\n' "${NEW_LINE}" >> "${ENV_FILE}"
fi

echo "post-commit: VITE_APP_VERSION=${VERSION}"
