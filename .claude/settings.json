{
  "model": "claude-opus-4-8",
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/nex-studio-src/scripts/hook_rag_reindex.sh",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
