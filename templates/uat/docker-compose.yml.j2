# UAT docker-compose template — per F-003 §3 + CR-022 amendment.
#
# Generic 3-service stack (postgres + backend + frontend) renderovaný cez
# scripts/_uat_lib.render_template() s placeholdermi:
#
#   SLUG                     — UAT slug (e.g. "mager", "dev")
#   UAT_PORT                 — alokovaný port z bloku 19500-19599 (frontend HTTPS via NGINX)
#   BACKEND_HOST_PORT        — host-side backend port (UAT_PORT + 100)
#   BACKEND_PORT             — container-side backend port (auto-detected, per CR-021)
#   BACKEND_HEALTHCHECK_TEST — healthcheck test array (auto-detected, per CR-021)
#   BACKEND_DOCKERFILE       — backend dockerfile path (auto-detected, per CR-021)
#   DB_PORT                  — internal postgres port (typicky UAT_PORT + 200)
#   PROJECT_PATH             — absolútna cesta zdroja /opt/projects/<projekt>
#   PROJECT_NAME             — projekt slug (pre image tagy)
#   POSTGRES_USER            — DB user (auto-detected per CR-022, default "postgres")
#   POSTGRES_DB              — DB name (auto-detected per CR-022, fallback "<project>_uat")
#   FRONTEND_CONTEXT         — frontend build context (auto-detected per CR-022)
#   FRONTEND_DOCKERFILE      — frontend dockerfile path (auto-detected per CR-022)
#   FRONTEND_BUILD_ARGS      — dict of build args (e.g. VITE_API_BASE_URL)
#
# Backend env vars: read from .env file (generated by uat-deploy s detected +
# synthetic vars per CR-022 §C-1). Žiadny hardcoded DATABASE_URL/UAT_SLUG block.

networks:
  uat-{{ SLUG }}-net:
    name: uat-{{ SLUG }}-net

services:
  postgres:
    image: postgres:16-alpine
    container_name: uat-{{ SLUG }}-postgres
    restart: "no"
    environment:
      POSTGRES_USER: {{ POSTGRES_USER | default("postgres") }}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      POSTGRES_DB: {{ POSTGRES_DB | default(PROJECT_NAME + "_uat") }}
    volumes:
      - uat-{{ SLUG }}-postgres-data:/var/lib/postgresql/data
    ports:
      - "127.0.0.1:{{ DB_PORT }}:5432"
    networks:
      - uat-{{ SLUG }}-net
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ POSTGRES_USER | default('postgres') }} -d {{ POSTGRES_DB | default(PROJECT_NAME + '_uat') }}"]
      interval: 5s
      timeout: 3s
      retries: 10

  backend:
    image: uat-{{ SLUG }}-backend:latest
    container_name: uat-{{ SLUG }}-backend
    restart: "no"
    build:
      context: {{ PROJECT_PATH }}
      dockerfile: {{ BACKEND_DOCKERFILE }}
    depends_on:
      postgres:
        condition: service_healthy
    env_file:
      - .env
    ports:
      - "127.0.0.1:{{ BACKEND_HOST_PORT }}:{{ BACKEND_PORT }}"
    networks:
      - uat-{{ SLUG }}-net
    healthcheck:
      test: {{ BACKEND_HEALTHCHECK_TEST | tojson }}
      interval: 10s
      timeout: 5s
      retries: 12
      start_period: 90s

  frontend:
    image: uat-{{ SLUG }}-frontend:latest
    container_name: uat-{{ SLUG }}-frontend
    restart: "no"
    build:
      context: {{ FRONTEND_CONTEXT | default(PROJECT_PATH + "/frontend") }}
      dockerfile: {{ FRONTEND_DOCKERFILE | default("Dockerfile") }}
      {% if FRONTEND_BUILD_ARGS is defined and FRONTEND_BUILD_ARGS %}
      args:
        {% for key, value in FRONTEND_BUILD_ARGS.items() %}
        {{ key }}: {{ value }}
        {% endfor %}
      {% endif %}
    depends_on:
      backend:
        condition: service_healthy
    ports:
      - "127.0.0.1:{{ UAT_PORT }}:80"
    networks:
      - uat-{{ SLUG }}-net

volumes:
  uat-{{ SLUG }}-postgres-data:
    name: uat-{{ SLUG }}-postgres-data
