# UAT environment template — per F-003 §11 (UAT credentials oddelené od produkcie).
#
# Tento súbor je VZOR. Pri `python scripts/uat-deploy.py <slug>` skript vygeneruje
# konkrétny `/opt/uat/<slug>/.env` so syntetickými hodnotami (openssl rand -hex 32).
#
# UAT credentials sa NIKDY nepoužívajú v produkcii (per CLAUDE.md §4).

# --- Database ---
# Syntetic password — vygenerované pri uat-deploy, NIE produkčný credential.
POSTGRES_PASSWORD=__GENERATED_AT_DEPLOY__

# --- Application ---
# UAT slug (mager, dev, customer-name, ...). Použité v container names + DB names.
UAT_SLUG=__SET_AT_DEPLOY__

# Verzia projektu nasadená v tomto UAT (e.g. v0.2.0). Set z `git describe --tags`.
PROJECT_VERSION=__SET_AT_DEPLOY__

# --- Encryption keys ---
# Per F-003 §11: UAT vlastné šifrovacie kľúče (openssl rand -hex 32).
# NIKDY nepoužiť produkčné kľúče v UAT.
JWT_SECRET_KEY=__GENERATED_AT_DEPLOY__
DATA_ENCRYPTION_KEY=__GENERATED_AT_DEPLOY__

# --- External services (UAT sandbox endpoints) ---
# Per-projekt podľa potreby — sandbox IMAP, sandbox SMB, atď.
# IMAP_HOST=sandbox-imap.test.local
# IMAP_USER=uat-${UAT_SLUG}@test.local
# IMAP_PASSWORD=__GENERATED_AT_DEPLOY__
